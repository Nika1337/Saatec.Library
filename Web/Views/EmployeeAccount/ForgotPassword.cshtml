@model Nika1337.Library.Web.Models.EmployeeAccount.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<div class="container pt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <h5 class="card-header">Forgot Password</h5>
                <div class="card-body">
                    <form asp-action="ForgotPassword" method="post" class="needs-validation" novalidate>
                        @if (Model.CodeSent)
                        {
                            <div class="alert alert-info">
                                A verification code has been sent to your email address.
                            </div>
                        }
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" type="email" required readonly="@Model.CodeSent">
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        @if (Model.CodeSent)
                        {

                            <div class="mb-3">
                                <label asp-for="InputCode" class="form-label"></label>
                                <input asp-for="InputCode" class="form-control" required>
                            </div>
                        }

                        <button type="submit" class="btn btn-dark w-100">
                            @(Model.CodeSent ? "Verify Code" : "Send Verification Code")
                        </button>

                        @if (Model.ErrorMessage != null)
                        {
                            <div class="alert alert-danger mt-3">"@Model.ErrorMessage"</div>
                        }
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            'use strict';
            window.addEventListener('load', function () {
                var form = document.getElementsByClassName('needs-validation')[0];
                form.addEventListener('submit', function (event) {
                    if (form.checkValidity() === false) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                }, false);
            }, false);
        })();

    </script>
}
